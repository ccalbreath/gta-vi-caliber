#!/usr/bin/env python
"""Builds all GDExtension modules under src/ into game/bin/.

Standard godot-cpp build: https://docs.godotengine.org/en/stable/tutorials/scripting/gdextension/gdextension_cpp_example.html
Usage:
    scons platform=<macos|linux|windows> target=<template_debug|template_release>
    scons tests        # also build bin/test_worldcore (plain C++ unit tests)
"""
import os
import sys

if not os.path.isdir("godot-cpp"):
    sys.exit(
        "godot-cpp submodule missing.\n"
        "Run: git submodule update --init --recursive\n"
        "(see engine/README.md for the version pin)"
    )

env = SConscript("godot-cpp/SConstruct")

env.Append(CPPPATH=["src/"])
sources = Glob("src/*.cpp") + Glob("src/*/*.cpp")

LIB_NAME = "worldcore"

if env["platform"] == "macos":
    library = env.SharedLibrary(
        "../game/bin/lib{0}.{1}.{2}.framework/lib{0}.{1}.{2}".format(
            LIB_NAME, env["platform"], env["target"]
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "../game/bin/lib{}{}{}".format(LIB_NAME, env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

# The manifest is copied (not symlinked) so game/bin/ works standalone.
manifest = env.Command(
    "../game/bin/worldcore.gdextension",
    "worldcore.gdextension.example",
    Copy("$TARGET", "$SOURCE"),
)

Default([library, manifest])

# Plain C++ unit tests (no Godot runtime needed): `scons tests`.
test_env = env.Clone()
test_program = test_env.Program("bin/test_worldcore", ["tests/test_worldcore.cpp"])
Alias("tests", test_program)
