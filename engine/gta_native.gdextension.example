; Copy to game/bin/gta_native.gdextension after building (see engine/README.md).
; game/bin/ is gitignored — every developer builds their own native libraries.

[configuration]

entry_symbol = "gta_native_library_init"
compatibility_minimum = "4.6"

[libraries]

macos.debug = "res://bin/libgta_native.macos.template_debug.framework"
macos.release = "res://bin/libgta_native.macos.template_release.framework"
linux.debug.x86_64 = "res://bin/libgta_native.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libgta_native.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/libgta_native.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libgta_native.windows.template_release.x86_64.dll"
