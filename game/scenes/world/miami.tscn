light_volumetric_fog_energy = 1.6
shadow_enabled = true
shadow_blur = 0.8
directional_shadow_max_distance = 350.0

; Night key light. SkyController (resolves it by the name "Moon") aims it
; opposite the sun and ramps its cool energy with night_amount, so moonlit
; geometry reads cool and casts soft shadows instead of going pitch black.
[node name="Moon" type="DirectionalLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 80, 0)
light_color = Color(0.6, 0.7, 0.96, 1.0)
light_energy = 0.0
light_angular_distance = 1.0
shadow_blur = 1.4
directional_shadow_max_distance = 600.0

[node name="SkyController" type="Node" parent="." groups=["sky"]]
script = ExtResource("39_skyctl")
time_of_day = 17.5
day_length_seconds = 1200.0

[node name="FloridaBackdrop" type="Node3D" parent="."]
script = ExtResource("4_florida")

; Switches the backdrop neon light clusters (group "night_lights") on at dusk
; and off by day off the shared SkyController night clock — the legacy
; DayNightCycle that used to own this group isn't in this scene.
[node name="NightLightsSwitch" type="Node" parent="."]
script = ExtResource("45_nightlights")

[node name="CoastalProps" type="Node3D" parent="."]
script = ExtResource("40_coastal_props")

; Drivable bay crossings (MacArthur / Julia Tuttle / Venetian) that connect the
; mainland districts to the beaches into one continuous Florida landmass.
[node name="Causeways" type="Node3D" parent="."]
script = ExtResource("34_causeways")

; Biscayne Bay residential islands (Star/Palm/Hibiscus, Venetian chain) that the
; causeways thread between — iconic Miami/Vice City landmarks.
[node name="BayIslands" type="Node3D" parent="."]
script = ExtResource("35_islands")

[node name="Streamer" type="Node3D" parent="."]
script = ExtResource("3_streamer")
load_radius = 8500.0
unload_radius = 9500.0

; Districts sit up to ~6.5 km out; beyond ~2 km float32 jitter sets in, so the
; world is teleported back around the player. The streamer and mission
; waypoints reconstruct absolute coords from its origin_offset.
[node name="FloatingOrigin" type="Node" parent="."]
script = ExtResource("41_origin")

; Live weather: a rolling front (clear -> overcast -> rain -> clearing) that
; thickens the fog, darkens the sky-shader clouds, rains over the player, and
; wets the streets (world_wetness shader global). Fog densities stay near the
; authored Vice City air so clear weather keeps the warm golden-hour grade.
[node name="Weather" type="Node3D" parent="."]
script = ExtResource("5_weather")
front_length_sec = 360.0
start_cycle = 0.1
environment_path = NodePath("../WorldEnvironment")
rain_path = NodePath("Rain")
clear_fog_density = 8e-05
storm_fog_density = 0.006
rain_fog_boost = 0.004

[node name="Rain" type="Node3D" parent="Weather"]
script = ExtResource("40_rain")
intensity = 0.0

