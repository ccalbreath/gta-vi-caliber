[node name="StreamingHud" type="CanvasLayer" parent="."]
script = ExtResource("9_shud")

; --- Gameplay simulation: self-wiring system nodes ---------------------------
; These discover the player / weapon controller / each other through groups at
; runtime (player_health, player_stats, wanted, mission, bark, player), so the
; live HUD lights up and shooting in the city now has consequences. The dynamic
; directors stream pedestrians, traffic, and a wanted-driven police response
; around the player across the paged districts.

