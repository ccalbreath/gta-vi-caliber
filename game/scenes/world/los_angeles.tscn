[gd_scene load_steps=6 format=3]

; Unified Los Angeles world: every district projects against one shared world
; origin (downtown), so they sit at their true real-world offsets in a single
; scene. Today both load statically; this is the authoring layout a streaming
; system (M3) will later page in and out around the camera.

[ext_resource type="PackedScene" path="res://scenes/player/player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://scenes/ui/debug_hud.tscn" id="2_hud"]
[ext_resource type="Script" path="res://scripts/world/district_loader.gd" id="3_loader"]

[sub_resource type="ProceduralSkyMaterial" id="sky_mat"]
sky_top_color = Color(0.38, 0.52, 0.74, 1)
sky_horizon_color = Color(0.7, 0.72, 0.73, 1)
ground_horizon_color = Color(0.7, 0.72, 0.73, 1)
ground_bottom_color = Color(0.52, 0.52, 0.5, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
tonemap_mode = 2
ssao_enabled = true
glow_enabled = true
fog_enabled = true
fog_light_color = Color(0.74, 0.77, 0.8, 1)
fog_density = 0.0006

[node name="LosAngeles" type="Node3D" groups=["world"]]

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("env")

[node name="Sun" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866025, 0.383022, -0.321394, 0, 0.642788, 0.766044, 0.5, -0.663414, 0.55667, 0, 60, 0)
light_energy = 1.1
shadow_enabled = true
directional_shadow_max_distance = 600.0

[node name="Downtown" type="Node3D" parent="."]
script = ExtResource("3_loader")
district_path = "res://assets/world/downtown_la.json"
place_player = true

[node name="Hollywood" type="Node3D" parent="."]
script = ExtResource("3_loader")
district_path = "res://assets/world/hollywood.json"
place_player = false

[node name="SpawnPoint" type="Marker3D" parent="." groups=["spawn_points"]]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 0)

[node name="Player" parent="." instance=ExtResource("1_player")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 0)

[node name="DebugHud" parent="." instance=ExtResource("2_hud")]
