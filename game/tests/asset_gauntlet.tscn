[gd_scene load_steps=9 format=3]

; Asset integration gauntlet stage (docs/ASSET_PIPELINE.md §12).
; Replicates the LIVE miami.tscn rendering stack verbatim as of PR #33 —
; physical sky.gdshader + SkyController + the real Environment grade + the
; WorldQuality tier script — so assets are judged under real game conditions,
; never a plain test sky. Self-contained: miami.tscn is not referenced.
; Driven by tests/asset_gauntlet_capture.gd, which instances the asset under
; AssetAnchor and snaps SkyController.set_time_of_day() between shots
; (day_length_seconds = 0 keeps time frozen otherwise).

[ext_resource type="Shader" path="res://assets/shaders/sky.gdshader" id="1_sky"]
[ext_resource type="Script" path="res://scripts/world/sky_controller.gd" id="2_skyctl"]
[ext_resource type="Script" path="res://scripts/world/world_quality.gd" id="3_quality"]

[sub_resource type="ShaderMaterial" id="sky_mat"]
shader = ExtResource("1_sky")
shader_parameter/sun_direction = Vector3(0.41, 0.81, -0.42)
shader_parameter/sun_energy = 1.0
shader_parameter/moon_direction = Vector3(-0.41, -0.81, 0.42)
shader_parameter/night_amount = 0.0
shader_parameter/rayleigh_strength = 1.0
shader_parameter/mie_strength = 1.0
shader_parameter/mie_eccentricity = 0.76
shader_parameter/sun_intensity = 22.0
shader_parameter/exposure = 1.1
shader_parameter/sun_angular_size = 1.2
shader_parameter/sun_disk_color = Color(1, 0.95, 0.86, 1)
shader_parameter/cloud_coverage = 0.5
shader_parameter/cloud_density = 1.2
shader_parameter/cloud_height = 1200.0
shader_parameter/cloud_scale = 0.00055
shader_parameter/cloud_wind = Vector2(0.014, 0.007)
shader_parameter/cloud_base_color = Color(0.66, 0.69, 0.74, 1)
shader_parameter/cloud_lit_color = Color(1, 0.97, 0.9, 1)
shader_parameter/star_density = 0.18
shader_parameter/night_zenith = Color(0.012, 0.016, 0.035, 1)
shader_parameter/moon_color = Color(0.85, 0.88, 0.95, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")
radiance_size = 4

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 3
ambient_light_energy = 0.46
ambient_light_color = Color(0.92, 0.76, 0.62, 1.0)
tonemap_mode = 4
tonemap_exposure = 1.05
tonemap_white = 6.0
ssr_enabled = true
ssr_max_steps = 48
ssao_enabled = true
ssao_intensity = 2.2
ssil_enabled = true
glow_enabled = true
glow_intensity = 0.58
glow_strength = 0.76
glow_bloom = 0.14
glow_blend_mode = 1
glow_hdr_threshold = 0.85
fog_enabled = true
fog_light_color = Color(1.0, 0.72, 0.5, 1.0)
fog_density = 0.00008
fog_sky_affect = 0.0
fog_aerial_perspective = 0.12
volumetric_fog_enabled = true
volumetric_fog_density = 0.00008
volumetric_fog_albedo = Color(1.0, 0.86, 0.72, 1.0)
volumetric_fog_emission = Color(0.28, 0.18, 0.22, 1.0)
volumetric_fog_emission_energy = 0.0
volumetric_fog_length = 900.0
volumetric_fog_detail_spread = 1.6
volumetric_fog_ambient_inject = 0.05
adjustment_enabled = true
adjustment_contrast = 1.08
adjustment_saturation = 1.12
adjustment_brightness = 1.0

[sub_resource type="PlaneMesh" id="ground_mesh"]
size = Vector2(600, 600)

[sub_resource type="StandardMaterial3D" id="ground_mat"]
albedo_color = Color(0.32, 0.32, 0.31, 1.0)
roughness = 0.95

[node name="AssetGauntlet" type="Node3D"]

[node name="Sun" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.94, 0.18, -0.29, 0, 0.85, 0.53, 0.34, -0.5, 0.8, 0, 80, 0)
light_color = Color(1.0, 0.66, 0.4, 1.0)
light_energy = 0.92
light_angular_distance = 2.0
shadow_enabled = true
shadow_blur = 1.2
directional_shadow_max_distance = 900.0

[node name="SkyController" type="Node" parent="." groups=["sky"]]
script = ExtResource("2_skyctl")
time_of_day = 12.0
day_length_seconds = 0.0

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("env")
script = ExtResource("3_quality")
minimum_tier = 1

[node name="ReflectionProbe" type="ReflectionProbe" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 20, 0)
update_mode = 1
size = Vector3(160, 90, 160)

[node name="Ground" type="MeshInstance3D" parent="."]
mesh = SubResource("ground_mesh")
surface_material_override/0 = SubResource("ground_mat")

[node name="AssetAnchor" type="Marker3D" parent="."]
